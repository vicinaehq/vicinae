{
	"name": "@vicinae/api",
	"version": "0.0.0",
	"description": "TypeScript SDK to build Vicinae extensions",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"build": "tsc --outDir dist",
		"pack": "npm run build && npm pack",
		"docgen": "typedoc",
		"format": "biome format --write"
	},
	"bin": {
		"vici": "./dist/bin.js"
	},
	"files": [
		"dist",
		"types"
	],
	"keywords": [],
	"author": "",
	"license": "ISC",
	"types": [
		"./dist/index.d.ts"
	],
	"publishConfig": {
		"access": "public"
	},
	"main": "dist/index.js",
	"dependencies": {
		"@types/react": "19.1.17",
		"chokidar": "^4.0.3",
		"esbuild": "^0.25.2",
		"react": "19.1.1",
		"zod": "^4.0.17"
	},
	"peerDependencies": {
		"@types/node": ">=18"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.2",
		"@types/node": "24.3.0",
		"typedoc": "0.28.13",
		"typedoc-github-theme": "0.3.1",
		"typedoc-plugin-markdown": "4.8.1",
		"typescript": "5.9.2"
	},
	"repository": "vicinaehq/vicinae"
}
