// vicinae-file-indexer (server) <-> main server (client)

struct IndexerConfig {
  paths: string[];
  excluded_paths: string[];
};

enum FileCategory {
  Other,
  Directory,
  Image,
  Video,
  Audio,
  Document,
  Archive,
  Code,
  Application
};

struct QueryRequest {
  text: string;
  limit: int;
  category?: FileCategory;
};

struct FileMatch {
  path: string;
  rank: double;
  category: FileCategory;
};

struct QueryResponse {
  matches: FileMatch[];
};

enum ScanKind { Full, Incremental };
enum ScanState { Started, Succeeded, Failed, Interrupted };

struct ScanStatusEvent {
  scan_id: int;
  kind: ScanKind;
  state: ScanState;
  entrypoint: string;
  processed_file_count: uint;
};

service FileIndexer {
  fn configure(config: IndexerConfig) => void;
  fn rebuildIndex() => void;
  async fn query(req: QueryRequest) => QueryResponse;

  event scanStatusChanged(status: ScanStatusEvent);
}
