// C++ process (client) -> extension manager (server)
// The C++ process requests the extension manager to load/unload extensions, and receives
// a notification each time an extension requests/notifies something.
// At this layer, the manager is unaware what the payload is made of.
// The payload is in reality another rpc message belonging to the vicinae<->extension spec.

enum CommandMode {
  View,
  NoView
};

enum CommandEnv {
  Development,
  Production
};

enum LaunchType {
  User,
  Background,
  CommandLine
};

struct Capabilities {
  browserExtension: bool;
  windowManagement: bool;
  wallpaper: bool;
  fileSearch: bool;
};

struct LoadOptions {
  mode: CommandMode;
  env: CommandEnv;
  vicinae_path: string;
  entrypoint: string;
  is_raycast: bool;
  command_name: string;
  extension_id: string;
  extension_name: string;
  owner_or_author_name: string;
  arguments: any;
  preferences: any;
  launch_context: any;
  launch_type: LaunchType;
  capabilities: Capabilities;
  cwd?: string;
};

struct LoadResponse {
  session_id: string;
};

service Manager {
  fn load(opts: LoadOptions) => LoadResponse;
  fn unload(session_id: string) => bool;

  // C++ side signals to extension manager that its ready to process messages from said extension
  // Happens right after the C++ side gets the session id from `load` and stores it.
  // It is important to synchronize this way otherwise we can theoretically miss the first messages if the
  // extension loads too fast.
  fn ready(session_id: string) => bool;

  fn messageExtension(session_id: string, payload: string) => bool;

  event extensionMessage(session_id: string, payload: string);
  event extensionCrash(session_id: string, reason: string);
}
