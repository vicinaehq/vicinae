// manager (client) to extension (server)
// the worker is already provisioned but waiting for the manager to initialize it with extension info


enum CommandMode {
  View,
  NoView
};

enum CommandEnv {
  Development,
  Production
};

struct LaunchEventData {
  extension_name: string;
  command_name: string;
  mode: CommandMode;
  entrypoint: string;
  asset_path: string;
  support_path: string;
  //map<string, google.protobuf.Value> preference_values = 7;
  //map<string, google.protobuf.Value> argument_values = 8;
  is_raycast: bool;
  owner_or_author_name: string;
};

service Lifecycle {
  fn launch(data: LaunchEventData) => bool;
  fn shutdown() => bool;
  fn send_message(msg: string) => bool;
  event extension_message(msg: string);
}
